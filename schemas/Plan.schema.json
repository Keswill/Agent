{
  "$defs": {
    "Assignment": {
      "additionalProperties": false,
      "properties": {
        "assignment_id": {
          "pattern": "^assign_[0-9]{3,}$",
          "title": "Assignment Id",
          "type": "string"
        },
        "object_id": {
          "pattern": "^obj_[0-9]{3,}$",
          "title": "Object Id",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "rule_id": {
          "anyOf": [
            {
              "pattern": "^rule_[0-9]{3,}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rule Id"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string"
        },
        "constraints": {
          "items": {
            "type": "string"
          },
          "title": "Constraints",
          "type": "array"
        },
        "confidence": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        }
      },
      "required": [
        "assignment_id",
        "object_id",
        "target"
      ],
      "title": "Assignment",
      "type": "object"
    },
    "PlanAction": {
      "enum": [
        "inspect",
        "pick",
        "place",
        "skip",
        "replan"
      ],
      "title": "PlanAction",
      "type": "string"
    },
    "PlanStep": {
      "additionalProperties": false,
      "properties": {
        "step_id": {
          "minimum": 1,
          "title": "Step Id",
          "type": "integer"
        },
        "action": {
          "$ref": "#/$defs/PlanAction"
        },
        "object_id": {
          "anyOf": [
            {
              "pattern": "^obj_[0-9]{3,}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Object Id"
        },
        "target": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target"
        },
        "arguments": {
          "additionalProperties": true,
          "title": "Arguments",
          "type": "object"
        },
        "preconditions": {
          "items": {
            "type": "string"
          },
          "title": "Preconditions",
          "type": "array"
        },
        "expected_result": {
          "default": "",
          "title": "Expected Result",
          "type": "string"
        },
        "on_failure": {
          "default": "replan",
          "title": "On Failure",
          "type": "string"
        }
      },
      "required": [
        "step_id",
        "action"
      ],
      "title": "PlanStep",
      "type": "object"
    },
    "Rule": {
      "additionalProperties": false,
      "properties": {
        "rule_id": {
          "pattern": "^rule_[0-9]{3,}$",
          "title": "Rule Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/RuleKind"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "conditions": {
          "additionalProperties": true,
          "title": "Conditions",
          "type": "object"
        },
        "action": {
          "additionalProperties": true,
          "title": "Action",
          "type": "object"
        },
        "priority": {
          "default": 100,
          "maximum": 1000,
          "minimum": 0,
          "title": "Priority",
          "type": "integer"
        }
      },
      "required": [
        "rule_id",
        "kind",
        "description"
      ],
      "title": "Rule",
      "type": "object"
    },
    "RuleKind": {
      "enum": [
        "assignment",
        "safety",
        "priority",
        "validation"
      ],
      "title": "RuleKind",
      "type": "string"
    },
    "ValidationReport": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/ValidationStatus"
        },
        "errors": {
          "items": {
            "type": "string"
          },
          "title": "Errors",
          "type": "array"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        },
        "repaired": {
          "items": {
            "type": "string"
          },
          "title": "Repaired",
          "type": "array"
        }
      },
      "required": [
        "status"
      ],
      "title": "ValidationReport",
      "type": "object"
    },
    "ValidationStatus": {
      "enum": [
        "passed",
        "repaired",
        "failed"
      ],
      "title": "ValidationStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "request_id": {
      "title": "Request Id",
      "type": "string"
    },
    "instruction": {
      "title": "Instruction",
      "type": "string"
    },
    "object_table_ref": {
      "title": "Object Table Ref",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "rules": {
      "items": {
        "$ref": "#/$defs/Rule"
      },
      "title": "Rules",
      "type": "array"
    },
    "assignments": {
      "items": {
        "$ref": "#/$defs/Assignment"
      },
      "title": "Assignments",
      "type": "array"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/PlanStep"
      },
      "title": "Steps",
      "type": "array"
    },
    "validation": {
      "$ref": "#/$defs/ValidationReport"
    },
    "execution_contract": {
      "additionalProperties": true,
      "title": "Execution Contract",
      "type": "object"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    }
  },
  "required": [
    "request_id",
    "instruction",
    "object_table_ref"
  ],
  "title": "Plan",
  "type": "object"
}