APP_ENV=development
LOG_LEVEL=INFO
ARTIFACT_DIR=artifacts

# Backends: heuristic | openai_compatible
LLM_BACKEND=heuristic

# Segmentation backends: stub | http | yolo | sam | ultralytics
SEGMENTATION_BACKEND=stub
SEGMENTATION_ENDPOINT=http://127.0.0.1:9000/segment

# Real vision backend. yolo uses YOLO(...); sam uses SAM(...) when ultralytics is installed.
ULTRALYTICS_MODEL_FAMILY=yolo
ULTRALYTICS_MODEL_PATH=yolo11n.pt
ULTRALYTICS_CONF=0.25
ULTRALYTICS_DEVICE=
ENABLE_COLOR_INFERENCE=false

# Agent integration: native | langchain
AGENT_INTEGRATION=native

# OpenAI-compatible chat completions endpoint, used when LLM_BACKEND=openai_compatible.
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4.1-mini

# Keep failure payloads and intermediate artifacts for debugging.
ENABLE_FAILURE_DUMPS=true
